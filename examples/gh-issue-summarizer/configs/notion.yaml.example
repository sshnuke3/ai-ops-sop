# gh-issue-summarizer Notion 配置示例
# 真实凭证不走这里——走环境变量 NOTION_API_KEY

# Notion 数据库 ID（从 Notion 数据库 URL 提取）
database_id: "REPLACE_WITH_YOUR_DATABASE_ID"

# 字段映射：本项目字段 → Notion 数据库字段名
field_mapping:
  issue_ref: "Issue Ref"
  repo: "Repo"
  title: "Title"
  url: "URL"
  summary: "3 句总结（中文）"
  score: "Score"
  comments: "Comments"
  prompt_version: "Prompt Version"
  prompt_hash: "Prompt Hash"
  week_of: "Week Of"   # YYYY-MM-DD 格式，本周一日期

# Notion 官方限流 3 req/s，我们硬上限 2 req/s
rate_limit:
  requests_per_second: 2
  burst: 1

# 重试
retry:
  max_attempts: 3
  backoff_seconds: [1, 2, 4]   # 1s, 2s, 4s 指数

# === 配置文件填法注释 ===
# 1. field_mapping 必须与 Notion 数据库里的列名一字不差——拼写错触发 A 分诊
# 2. rate_limit 不可调高——超 3 req/s 会触发 429，触发 RL-PRJ-2
# 3. retry.backoff 必须有 ≥ 3 段——指数退避是 Notion 推荐姿势
# 4. database_id 必填——空值触发 schema 验证失败（RL-60）
